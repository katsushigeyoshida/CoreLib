<Window x:Class="CoreLib.InputBoxMulti"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CoreLib"
        mc:Ignorable="d"
        Title="InputBoxMulti" Height="300" Width="300" Loaded="Window_Loaded" Closing="Window_Closing" LayoutUpdated="Window_LayoutUpdated">
    <Grid >
        <StackPanel Name="stackPanel" Margin="0,0,0,40">
            <StatusBar>
                <TextBlock Text="タイトル" />
            </StatusBar>
        </StackPanel>
        <Button Content="OK" IsDefault="True" HorizontalAlignment="Right" Width="50" Height="20" VerticalAlignment="Bottom" Margin="0,0,100,10" Click="Button_Click"/>
        <Button Content="Cancel" HorizontalAlignment="Right" Width="50" Height="20" VerticalAlignment="Bottom" Margin="0,0,30,10" Click="Button_Click_1"/>
    </Grid>
</Window>
